<!DOCTYPE html>
<html lang="en">
    <head>
        <title>Student Registration</title>

        <link rel="stylesheet" href="form.css">
        <style>
            *{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:#f3f6fb;
    display:flex;
    justify-content:center;
    align-items:center;
    min-height:100vh;
}

.container{
    width:420px;
    background:#fff;
    padding:30px;
    border-radius:12px;
    box-shadow:0 8px 20px rgba(0,0,0,.15);
}

.container h2{
    text-align:center;
    color:#2c3e50;
    margin-bottom:25px;
}

.input-box{
    margin-bottom:18px;
}

.input-box label{
    display:block;
    margin-bottom:6px;
    font-weight:bold;
    color:#444;
}

.input-box input,
.input-box select{
    width:100%;
    padding:12px;
    border:1px solid #ccc;
    border-radius:8px;
    font-size:15px;
    outline:none;
    transition:.3s;
}

.input-box input:focus,
.input-box select:focus{
    border-color:#4a90e2;
}

.btn{
    width:100%;
    padding:13px;
    background:#4a90e2;
    color:white;
    border:none;
    border-radius:8px;
    font-size:16px;
    font-weight:bold;
    cursor:pointer;
    transition:.3s;
}

.btn:hover{
    background:#357bd8;
}
        </style>
    </head>
    <body>
        <div class="container">
            <h2>Student Registration</h2>

            <form action="/update/<%= stud.stud_id %>/<%= stud.photo %>" method="POST" enctype="multipart/form-data">
                <div class="input-box">
                    <label>Student Name</label>
                    <input type="text" name="student_name" value="<%= stud.student_name %>" placeholder="Enter Student Name">
                </div>

                <div class="input-box">
                    <label>Email</label>
                    <input type="email" name="email" value="<%= stud.email %>" placeholder="Enter Email">
                </div>

                <div class="input-box">
                    <label>Mobile</label>
                    <input type="text" name="mobile" value="<%= stud.mobile %>" placeholder="Enter Mobile Number">
                </div>

                <div class="input-box">
                    <label>Course</label>
                    <select name="course">
                        <option>Choose Course</option>
                        <option value="BCA" <%= stud.course=='BCA' ? 'selected' : '' %>>BCA</option>
                        <option value="BSc" <%= stud.course=='BSc' ? 'selected' : '' %>>BSc</option>
                        <option value="BBA" <%= stud.course=='BBA' ? 'selected' : '' %>>BBA</option>
                        <option value="MCA" <%= stud.course=='MCA' ? 'selected' : '' %>>MCA</option>
                        <option value="MSc" <%= stud.course=='MSc' ? 'selected' : '' %>>MSc</option>
                    </select>
                </div>

                <div class="input-box">
                    <label>City</label>
                    <input type="text" name="city" value="<%= stud.city %>" placeholder="Enter City">
                </div>

                <div class="input-box">
                    <label>Student Photo</label>
                    <input type="file" name="photo"><br><br>
                    <img src="/<%= stud.photo %>" height="100px"><br><br>
                </div>

                <button class="btn" type="submit">Update Student</button>

            </form>

        </div>

    </body>
</html>